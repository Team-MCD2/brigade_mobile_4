---
const year = new Date().getFullYear();
---

<footer class="site-footer">
    <div class="container">
        <div class="footer-grid">
            <div class="footer-col">
                <img src="/logo.png" alt="La Brigade Mobile" style="height:40px; margin-bottom:1rem; filter:brightness(0) invert(1);">
                <p style="color:#ccc; margin-bottom:1rem;">Expert en réparation & reconditionnement. La tech durable à Toulouse.</p>
            </div>
            <div class="footer-col">
                <h4>Nos Services</h4>
                <ul>
                    <li><a href="/reparation">Réparation Smartphone</a></li>
                    <li><a href="/reparation">Réparation Ordinateur</a></li>
                    <li><a href="/smartphones">Vente Reconditionné</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h4>Informations</h4>
                <ul>
                    <li><a href="/a-propos">L'Atelier</a></li>
                    <li><a href="/devis">Contact & Devis</a></li>
                    <li><a href="/#faq">FAQ</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h4>Contact Toulouse</h4>
                <p style="color:#ccc; font-size:0.9rem; line-height:1.4;"><span class="material-symbols-outlined icon-small">location_on</span> 65 Route de Blagnac, 31300 Toulouse</p>
                <p style="color:#ccc; font-size:0.9rem;"><span class="material-symbols-outlined icon-small">call</span> 07 56 91 65 93</p>
                <p style="color:#ccc; font-size:0.9rem;"><span class="material-symbols-outlined icon-small">schedule</span> Lun-Ven : 9h-19h | Sam : 10h-18h</p>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; {year} La Brigade Mobile par ReparePhone Toulouse — Tous droits réservés</p>
        </div>
    </div>
</footer>
