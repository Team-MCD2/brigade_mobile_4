---
import RequestList  from '../components/RequestList';
import DetailPanel  from '../components/DetailPanel';
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin · Brigade Mobile</title>
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:         #080808;
      --surface:    #0f0f0f;
      --border:     rgba(255,255,255,0.07);
      --border-h:   rgba(255,255,255,0.12);
      --text:       #e8e8e8;
      --muted:      #484848;
      --faint:      #272727;
      --accent:     #c94f00;
      --green:      #22c55e;
      --amber:      #f59e0b;
      --red:        #ef4444;
      --blue:       #3b82f6;
      --header-h:   52px;
      --sidebar-w:  300px;
      --font:       -apple-system, BlinkMacSystemFont, "SF Pro Text", "Segoe UI", sans-serif;
      --mono:       "SF Mono", "Fira Code", "Cascadia Code", monospace;
    }

    html, body {
      height: 100%;
      background: var(--bg);
      color: var(--text);
      font-family: var(--font);
      font-size: 13px;
      line-height: 1.5;
      -webkit-font-smoothing: antialiased;
    }

    /* ── HEADER ──────────────────────────────────────────────── */
    .header {
      position: fixed;
      top: 0; left: 0; right: 0;
      height: var(--header-h);
      background: rgba(8,8,8,0.85);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 1.25rem;
      z-index: 100;
      gap: 1rem;
    }

    .header-brand {
      text-decoration: none;
      cursor: pointer;
      transition: opacity 0.15s;
    }
    .header-brand:hover { opacity: 0.65; }
    .header-brand {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      flex-shrink: 0;
    }
    .header-brand .wordmark {
      font-size: 0.875rem;
      font-weight: 700;
      letter-spacing: -0.01em;
      color: #fff;
    }
    .header-brand .admin-badge {
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--accent);
      background: rgba(201,79,0,0.12);
      border: 1px solid rgba(201,79,0,0.25);
      padding: 2px 7px;
      border-radius: 4px;
    }

    .header-nav {
      display: flex;
      align-items: center;
      gap: 0.25rem;
    }
    .header-nav a {
      text-decoration: none;
      font-size: 0.8rem;
      font-weight: 500;
      color: var(--muted);
      padding: 0.35rem 0.75rem;
      border-radius: 6px;
      transition: color 0.15s, background 0.15s;
    }
    .header-nav a:hover { color: var(--text); background: var(--faint); }
    .header-nav a.active { color: var(--text); }

    .header-right {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      flex-shrink: 0;
    }
    .live-dot {
      width: 7px; height: 7px;
      border-radius: 50%;
      background: var(--green);
      box-shadow: 0 0 6px var(--green);
      animation: pulse-dot 2s ease-in-out infinite;
    }
    @keyframes pulse-dot {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.4; }
    }
    .header-user {
      font-size: 0.78rem;
      color: var(--muted);
    }
    .header-avatar {
      width: 26px; height: 26px;
      border-radius: 50%;
      background: var(--faint);
      border: 1px solid var(--border-h);
      display: flex; align-items: center; justify-content: center;
      font-size: 0.7rem;
      font-weight: 700;
      color: var(--text);
    }

    /* ── LAYOUT ──────────────────────────────────────────────── */
    .layout {
      display: flex;
      height: 100vh;
      padding-top: var(--header-h);
    }

    /* ── SIDEBAR ─────────────────────────────────────────────── */
    .sidebar {
      width: var(--sidebar-w);
      flex-shrink: 0;
      height: 100%;
      overflow-y: auto;
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      scrollbar-width: none;
    }
    .sidebar::-webkit-scrollbar { display: none; }

    .sidebar-top {
      padding: 1.25rem 1.25rem 0.75rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-shrink: 0;
    }
    .sidebar-title {
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--muted);
    }
    .count-badge {
      font-size: 0.7rem;
      font-weight: 700;
      font-family: var(--mono);
      color: var(--muted);
      background: var(--faint);
      border: 1px solid var(--border);
      padding: 1px 7px;
      border-radius: 4px;
    }

    .filters {
      padding: 0 1rem 0.75rem;
      display: flex;
      gap: 0.3rem;
      flex-wrap: wrap;
      flex-shrink: 0;
    }
    .filter-btn {
      background: none;
      border: 1px solid var(--border);
      color: var(--muted);
      font-size: 0.72rem;
      font-weight: 500;
      padding: 0.3rem 0.7rem;
      border-radius: 6px;
      cursor: pointer;
      transition: all 0.15s;
      font-family: var(--font);
    }
    .filter-btn:hover { border-color: var(--border-h); color: var(--text); }
    .filter-btn.active {
      background: var(--faint);
      border-color: var(--border-h);
      color: var(--text);
    }

    .divider {
      height: 1px;
      background: var(--border);
      margin: 0 1rem 0.75rem;
      flex-shrink: 0;
    }

    .requests-list {
      flex: 1;
      padding: 0 0.4rem 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    /* ── Request card ──────────────────────── */
    .req-card {
      display: flex;
      align-items: flex-start;
      gap: 0.65rem;
      padding: 0.65rem 0.55rem;
      border-radius: 10px;
      cursor: pointer;
      transition: background 0.12s, border-color 0.12s;
      border: 1px solid transparent;
    }
    .req-card:hover {
      background: var(--faint);
      border-color: var(--border);
    }
    .req-card:hover .req-thumb { border-color: rgba(255,255,255,0.14); }
    .req-card--active {
      background: rgba(255,255,255,0.04);
      border-color: var(--border-h);
    }
    .req-card--active .req-name  { color: #fff; }
    .req-card--active .req-thumb { border-color: rgba(255,255,255,0.18); }
    .req-card--active .req-specs { color: #6a6a6a; }

    /* Phone thumbnail — crops the existing sprite */
    .req-thumb {
      width: 36px;
      min-width: 36px;
      height: 46px;
      border-radius: 7px;
      background-image: url('/phones-cards.png');
      background-size: 400% auto;
      background-repeat: no-repeat;
      border: 1px solid rgba(255,255,255,0.07);
      overflow: hidden;
      transition: border-color 0.12s;
    }
    .req-thumb--apple   { background-color: #e8e8ed; background-position:   0% 32%; }
    .req-thumb--samsung { background-color: #2a2a2a; background-position: 33.33% 32%; }
    .req-thumb--pixel   { background-color: #f0ede6; background-position: 66.66% 32%; }
    .req-thumb--autre   { background-color: #e8e6f0; background-position: 100%   32%; }

    .req-body {
      flex: 1;
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
    }
    .req-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.3rem;
    }
    .req-name {
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--text);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .req-specs {
      font-size: 0.68rem;
      color: var(--muted);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .req-foot {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-top: 0.05rem;
    }
    .req-date {
      font-size: 0.66rem;
      color: #424242;
    }
    .req-price {
      font-size: 0.74rem;
      font-weight: 700;
      font-family: var(--mono);
      color: var(--accent);
      letter-spacing: -0.01em;
    }

    .status-pill {
      font-size: 0.61rem;
      font-weight: 600;
      letter-spacing: 0.03em;
      padding: 1px 6px;
      border-radius: 4px;
      flex-shrink: 0;
      white-space: nowrap;
    }
    .status-pill.pending  { background: rgba(245,158,11,0.12); color: var(--amber); }
    .status-pill.done     { background: rgba(34,197,94,0.10);  color: var(--green); }
    .status-pill.refused  { background: rgba(239,68,68,0.10);  color: var(--red);   }
    .status-pill.review   { background: rgba(59,130,246,0.10); color: var(--blue);  }

    /* ── DETAIL ZONE ─────────────────────────────────────────── */
    .detail {
      flex: 1;
      height: 100%;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      min-width: 0;
    }

    .detail-toolbar {
      height: 44px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      padding: 0 1.75rem;
      gap: 0.6rem;
      flex-shrink: 0;
    }
    .toolbar-crumb {
      font-size: 0.75rem;
      color: var(--muted);
    }
    .toolbar-sep { font-size: 0.72rem; color: var(--border-h); }

    /* ── Detail panel ── */
    .dp-scroll {
      flex: 1;
      overflow-y: auto;
      padding: 3.5rem 4rem;
      display: flex;
      flex-direction: column;
      gap: 3.5rem;
    }

    /* Empty state */
    .dp-empty {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 1rem;
      padding: 4rem;
    }
    .dp-empty-icon {
      width: 48px; height: 48px;
      border: 1px solid var(--border);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--muted);
    }
    .dp-empty-title {
      font-size: 0.92rem; font-weight: 600; color: var(--text); letter-spacing: -0.01em;
    }
    .dp-empty-sub {
      font-size: 0.78rem; color: var(--muted);
      text-align: center; max-width: 280px; line-height: 1.65;
    }

    /* ── Hero — Apple product page style ── */
    .dp-hero {
      display: flex;
      gap: 4rem;
      align-items: center;
      padding-bottom: 1rem;
    }

    /* Large dominant phone image */
    .dp-phone-img {
      width: 210px;
      min-width: 210px;
      height: 270px;
      border-radius: 22px;
      background-image: url('/phones-cards.png');
      background-size: 400% auto;
      background-repeat: no-repeat;
      border: 1px solid var(--border);
      box-shadow: 0 24px 60px rgba(0,0,0,0.45), 0 8px 20px rgba(0,0,0,0.25);
    }
    .dp-phone-img--apple   { background-color: #e8e8ed; background-position:   0% 32%; }
    .dp-phone-img--samsung { background-color: #2a2a2a; background-position: 33.33% 32%; }
    .dp-phone-img--pixel   { background-color: #f0ede6; background-position: 66.66% 32%; }
    .dp-phone-img--autre   { background-color: #e8e6f0; background-position: 100%   32%; }

    /* Hero info column */
    .dp-hero-info {
      flex: 1;
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 0;
    }
    .dp-hero-brand {
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 0.75rem;
    }
    .dp-phone-name {
      font-size: 2.4rem;
      font-weight: 700;
      color: var(--text);
      letter-spacing: -0.04em;
      line-height: 1.05;
      margin-bottom: 2rem;
    }
    .dp-hero-rule {
      width: 2rem;
      height: 1px;
      background: var(--border-h);
      margin-bottom: 2rem;
    }
    .dp-price-block { margin-bottom: 0.5rem; }
    .dp-price {
      font-size: 3.8rem;
      font-weight: 800;
      font-family: var(--mono);
      color: var(--accent);
      letter-spacing: -0.06em;
      line-height: 1;
    }
    .dp-price-caption {
      font-size: 0.65rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--muted);
      margin-top: 0.5rem;
    }
    .dp-hero-meta {
      font-size: 0.72rem;
      color: #353535;
      margin-top: 2rem;
      letter-spacing: 0.01em;
    }

    /* Section */
    .dp-section {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .dp-section-title {
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--muted);
      padding-bottom: 0.65rem;
      border-bottom: 1px solid var(--border);
    }
    .dp-grid-2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.5rem;
    }
    .dp-row {
      background: var(--faint);
      border: 1px solid var(--border);
      border-radius: 9px;
      padding: 0.7rem 1rem;
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
    }
    .dp-row-label {
      font-size: 0.63rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      color: var(--muted);
    }
    .dp-row-value { font-size: 0.82rem; font-weight: 600; color: var(--text); }

    /* Client card */
    .dp-client-card {
      display: flex;
      align-items: center;
      gap: 1.25rem;
      background: var(--faint);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.1rem 1.4rem;
    }
    .dp-avatar {
      width: 42px; height: 42px;
      border-radius: 50%;
      background: rgba(201,79,0,0.12);
      border: 1px solid rgba(201,79,0,0.22);
      display: flex; align-items: center; justify-content: center;
      font-size: 0.82rem; font-weight: 700; color: var(--accent);
      flex-shrink: 0; letter-spacing: 0.02em;
    }
    .dp-client-info { flex: 1; min-width: 0; }
    .dp-client-name {
      font-size: 0.88rem; font-weight: 600; color: var(--text);
      margin-bottom: 0.2rem;
    }
    .dp-client-contact {
      font-size: 0.75rem; color: var(--muted);
    }

    /* Actions */
    .dp-actions {
      display: flex;
      gap: 0.75rem;
    }
    .dp-btn {
      flex: 1;
      padding: 0.8rem 1rem;
      border-radius: 10px;
      font-size: 0.82rem;
      font-weight: 600;
      font-family: var(--font);
      cursor: pointer;
      transition: background 0.15s, border-color 0.15s;
      border: 1px solid transparent;
    }
    .dp-btn--validate {
      background: rgba(34,197,94,0.10);
      border-color: rgba(34,197,94,0.22);
      color: var(--green);
    }
    .dp-btn--validate:hover { background: rgba(34,197,94,0.18); }
    .dp-btn--refuse {
      background: rgba(239,68,68,0.08);
      border-color: rgba(239,68,68,0.18);
      color: var(--red);
    }
    .dp-btn--refuse:hover { background: rgba(239,68,68,0.16); }
    .dp-btn--contact {
      background: none;
      border-color: var(--border-h);
      color: var(--text);
    }
    .dp-btn--contact:hover { background: var(--faint); }

    @media (max-width: 1100px) {
      .dp-scroll { padding: 2.5rem 2.5rem; gap: 2.5rem; }
      .dp-hero { gap: 2.5rem; }
      .dp-phone-img { width: 170px; min-width: 170px; height: 218px; }
      .dp-phone-name { font-size: 1.9rem; margin-bottom: 1.5rem; }
      .dp-price { font-size: 3rem; }
      .dp-hero-rule { margin-bottom: 1.5rem; }
      .dp-hero-meta { margin-top: 1.5rem; }
    }
    @media (max-width: 860px) {
      .dp-scroll { padding: 2rem 1.5rem; }
      .dp-hero { flex-direction: column; align-items: flex-start; gap: 1.5rem; }
      .dp-phone-img { width: 100%; min-width: unset; height: 200px;
        background-size: 400% auto; border-radius: 16px; }
    }

    /* ── STATS ROW (sidebar bottom) ──────────────────────────── */
    .stats-row {
      padding: 1rem 1.25rem;
      border-top: 1px solid var(--border);
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.6rem;
      flex-shrink: 0;
    }
    .stat-cell {
      background: var(--faint);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 0.6rem 0.75rem;
    }
    .stat-label {
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--muted);
      display: block;
      margin-bottom: 0.2rem;
    }
    .stat-value {
      font-size: 1.1rem;
      font-weight: 800;
      font-family: var(--mono);
      letter-spacing: -0.03em;
      color: var(--text);
    }
    .stat-value.accent { color: var(--accent); }
    .stat-value.green  { color: var(--green);  }

    /* ── RESPONSIVE ──────────────────────────────────────────── */
    @media (max-width: 768px) {
      :root { --sidebar-w: 100%; }

      .header-nav { display: none; }
      .header-user { display: none; }

      .layout {
        flex-direction: column;
        height: auto;
        min-height: 100vh;
        overflow-y: auto;
      }

      .sidebar {
        width: 100%;
        height: auto;
        max-height: none;
        border-right: none;
        border-bottom: 1px solid var(--border);
        overflow-y: visible;
      }

      .requests-list { max-height: 420px; overflow-y: auto; }

      .stats-row { grid-template-columns: repeat(4, 1fr); }

      .detail { display: none; }
    }

    @media (max-width: 480px) {
      .header-brand .wordmark { font-size: 0.8rem; }
      .stats-row { grid-template-columns: repeat(2, 1fr); }
      .filters { gap: 0.2rem; }
      .filter-btn { font-size: 0.68rem; padding: 0.25rem 0.55rem; }
    }
  </style>
</head>
<body>

  <!-- ── HEADER ── -->
  <header class="header">
    <a href="/" class="header-brand" title="Retour au site">
      <span class="wordmark">Brigade Mobile</span>
      <span class="admin-badge">Admin</span>
    </a>

    <nav class="header-nav">
      <a href="#" class="active">Reprises</a>
      <a href="#">Catalogue</a>
      <a href="#">Revenus</a>
      <a href="#">Paramètres</a>
    </nav>

    <div class="header-right">
      <div class="live-dot"></div>
      <span class="header-user">En ligne</span>
      <div class="header-avatar">A</div>
    </div>
  </header>

  <!-- ── LAYOUT ── -->
  <div class="layout">

    <!-- ── SIDEBAR ── -->
    <aside class="sidebar">

      <div class="sidebar-top">
        <span class="sidebar-title">Demandes</span>
        <span class="count-badge">12</span>
      </div>

      <div class="filters">
        <button class="filter-btn active">Toutes</button>
        <button class="filter-btn">En attente</button>
        <button class="filter-btn">Validées</button>
        <button class="filter-btn">Refusées</button>
      </div>

      <div class="divider"></div>

      <RequestList client:load />

      <!-- Stats -->
      <div class="stats-row">
        <div class="stat-cell">
          <span class="stat-label">Ce mois</span>
          <span class="stat-value green">47</span>
        </div>
        <div class="stat-cell">
          <span class="stat-label">Marge totale</span>
          <span class="stat-value accent">9 400 €</span>
        </div>
        <div class="stat-cell">
          <span class="stat-label">En attente</span>
          <span class="stat-value">4</span>
        </div>
        <div class="stat-cell">
          <span class="stat-label">Taux valid.</span>
          <span class="stat-value">79%</span>
        </div>
      </div>

    </aside>

    <!-- ── DETAIL ZONE ── -->
    <DetailPanel client:load />

  </div>

</body>
</html>
