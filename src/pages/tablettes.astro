---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Tablettes Reconditionnées | La Brigade Mobile">
    <main>
        <section class="hero-slim" style="background-image: url('https://images.unsplash.com/photo-1544244015-0df4b3ffc6b0?q=80&w=1920');">
            <div class="container" style="position:relative; z-index:2;">
                <h1 style="font-size:3rem; text-transform:uppercase; margin-bottom:0.5rem; color:white;">Tablettes Reconditionnées</h1>
                <p style="color:#f0f0f0;">iPad, Galaxy Tab et plus. Testées et garanties 12 mois.</p>
            </div>
        </section>

        <section class="container catalog-container">
            <aside class="sidebar-filters fade-in-up">
                <div class="filter-group">
                    <h4>Marque</h4>
                    <label class="filter-label"><input type="checkbox" name="brand" value="Apple"> Apple iPad</label>
                    <label class="filter-label"><input type="checkbox" name="brand" value="Samsung"> Samsung</label>
                    <label class="filter-label"><input type="checkbox" name="brand" value="Lenovo"> Lenovo</label>
                </div>
                <div class="filter-group">
                    <h4>État</h4>
                    <label class="filter-label"><input type="checkbox" name="etat" value="Comme neuf"> Comme neuf</label>
                    <label class="filter-label"><input type="checkbox" name="etat" value="Très bon état"> Très bon état</label>
                    <label class="filter-label"><input type="checkbox" name="etat" value="Bon état"> Bon état</label>
                </div>
                <div class="filter-group">
                    <h4>Prix Max: <span id="price-val">800€</span></h4>
                    <input type="range" id="price-filter" min="0" max="1500" value="800" style="width:100%;">
                    <div style="display:flex; justify-content:space-between; font-size:0.9rem; color:#666; margin-top:0.5rem;">
                        <span>0€</span><span>1500€</span>
                    </div>
                </div>
            </aside>

            <div>
                <div style="margin-bottom:2rem; display:flex; justify-content:space-between; align-items:center;">
                    <p><strong id="product-count">2</strong> produits affichés</p>
                    <select id="sort-filter" style="padding:0.5rem; border:1px solid #ddd; border-radius:4px; outline:none;">
                        <option value="default">Pertinence</option>
                        <option value="price-asc">Prix croissant</option>
                        <option value="price-desc">Prix décroissant</option>
                    </select>
                </div>
                <div class="products-grid" id="products-grid">
                    <div class="product-card fade-in-up visible" data-brand="Apple" data-etat="Très bon état" data-cap="64 Go" data-price="399">
                        <span class="badge-etat etat-tb">Très bon état</span>
                        <img src="https://images.unsplash.com/photo-1585790050230-5dd28404ccb9?q=80&w=400" alt="iPad Air 4" class="product-img">
                        <h3 class="product-title">Apple iPad Air 4 - 64 Go</h3>
                        <div class="product-price-wrapper">
                            <span class="price-old">669€</span>
                            <span class="price-new">399€</span>
                        </div>
                        <a href="/product?name=iPad%20Air%204&price=399&img=https://images.unsplash.com/photo-1585790050230-5dd28404ccb9?q=80&w=600" class="btn-primary">Détails & Devis</a>
                    </div>
                    <div class="product-card fade-in-up visible" data-brand="Samsung" data-etat="Comme neuf" data-cap="128 Go" data-price="329">
                        <span class="badge-etat etat-neuf">Comme neuf</span>
                        <img src="https://images.unsplash.com/photo-1544244015-0df4b3ffc6b0?q=80&w=400" alt="Galaxy Tab S8" class="product-img">
                        <h3 class="product-title">Samsung Galaxy Tab S8 - 128 Go</h3>
                        <div class="product-price-wrapper">
                            <span class="price-old">599€</span>
                            <span class="price-new">329€</span>
                        </div>
                        <a href="/product?name=Samsung%20Galaxy%20Tab%20S8&price=329&img=https://images.unsplash.com/photo-1544244015-0df4b3ffc6b0?q=80&w=600" class="btn-primary">Détails & Devis</a>
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>
