---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Smartphones Reconditionnés | La Brigade Mobile">
    <main>
        <section class="hero-slim">
            <div class="container" style="position:relative; z-index:2;">
                <h1 style="font-size:3rem; text-transform:uppercase; margin-bottom:0.5rem; color:white;">Smartphones Reconditionnés</h1>
                <p style="color:#f0f0f0;">Jusqu'à -70% sur des milliers de téléphones vérifiés et garantis.</p>
            </div>
        </section>

        <section class="container catalog-container">
            <aside class="sidebar-filters fade-in-up">
                <div class="filter-group">
                    <h4>Marque</h4>
                    <label class="filter-label"><input type="checkbox" name="brand" value="Apple"> Apple</label>
                    <label class="filter-label"><input type="checkbox" name="brand" value="Samsung"> Samsung</label>
                    <label class="filter-label"><input type="checkbox" name="brand" value="Google"> Google</label>
                    <label class="filter-label"><input type="checkbox" name="brand" value="Xiaomi"> Xiaomi</label>
                </div>
                <div class="filter-group">
                    <h4>État</h4>
                    <label class="filter-label"><input type="checkbox" name="etat" value="Comme neuf"> Comme neuf</label>
                    <label class="filter-label"><input type="checkbox" name="etat" value="Très bon état"> Très bon état</label>
                    <label class="filter-label"><input type="checkbox" name="etat" value="Bon état"> Bon état</label>
                </div>
                <div class="filter-group">
                    <h4>Capacité</h4>
                    <label class="filter-label"><input type="checkbox" name="cap" value="64 Go"> 64 Go</label>
                    <label class="filter-label"><input type="checkbox" name="cap" value="128 Go"> 128 Go</label>
                    <label class="filter-label"><input type="checkbox" name="cap" value="256 Go"> 256 Go</label>
                    <label class="filter-label"><input type="checkbox" name="cap" value="512 Go"> 512 Go</label>
                </div>
                <div class="filter-group">
                    <h4>Prix Max: <span id="price-val">800€</span></h4>
                    <input type="range" id="price-filter" min="0" max="1500" value="800" style="width:100%;">
                    <div style="display:flex; justify-content:space-between; font-size:0.9rem; color:#666; margin-top:0.5rem;">
                        <span>0€</span><span>1500€</span>
                    </div>
                </div>
            </aside>

            <div>
                <div style="margin-bottom:2rem; display:flex; justify-content:space-between; align-items:center;">
                    <p><strong id="product-count">3</strong> produits affichés</p>
                    <select id="sort-filter" style="padding:0.5rem; border:1px solid #ddd; border-radius:4px; outline:none;">
                        <option value="default">Pertinence</option>
                        <option value="price-asc">Prix croissant</option>
                        <option value="price-desc">Prix décroissant</option>
                    </select>
                </div>
                <div class="products-grid" id="products-grid">
                    <div class="product-card fade-in-up visible" data-brand="Apple" data-etat="Très bon état" data-cap="128 Go" data-price="459" style="transition-delay:0.1s;">
                        <span class="badge-etat etat-tb">Très bon état</span>
                        <img src="https://images.unsplash.com/photo-1592899677977-9c10ca588bbd?q=80&w=400" alt="iPhone 13" class="product-img">
                        <h3 class="product-title">Apple iPhone 13 - 128 Go</h3>
                        <div class="product-price-wrapper">
                            <span class="price-old">749€</span>
                            <span class="price-new">459€</span>
                        </div>
                        <a href="/product?name=Apple%20iPhone%2013&price=459&img=https://images.unsplash.com/photo-1592899677977-9c10ca588bbd?q=80&w=400" class="btn-primary">Détails & Devis</a>
                    </div>
                    <div class="product-card fade-in-up visible" data-brand="Samsung" data-etat="Comme neuf" data-cap="256 Go" data-price="389" style="transition-delay:0.2s;">
                        <span class="badge-etat etat-neuf">Comme neuf</span>
                        <img src="https://images.unsplash.com/photo-1610945265064-0e34e5519bbf?q=80&w=400" alt="Galaxy S22" class="product-img">
                        <h3 class="product-title">Samsung Galaxy S22 - 256 Go</h3>
                        <div class="product-price-wrapper">
                            <span class="price-old">859€</span>
                            <span class="price-new">389€</span>
                        </div>
                        <a href="/product?name=Samsung%20Galaxy%20S22&price=389&img=https://images.unsplash.com/photo-1610945265064-0e34e5519bbf?q=80&w=400" class="btn-primary">Détails & Devis</a>
                    </div>
                    <div class="product-card fade-in-up visible" data-brand="Google" data-etat="Bon état" data-cap="128 Go" data-price="379" style="transition-delay:0.3s;">
                        <span class="badge-etat etat-bon">Bon état</span>
                        <img src="https://images.unsplash.com/photo-1678911820864-e2c567c655d7?q=80&w=400" alt="Pixel 7" class="product-img">
                        <h3 class="product-title">Google Pixel 7 - 128 Go</h3>
                        <div class="product-price-wrapper">
                            <span class="price-old">649€</span>
                            <span class="price-new">379€</span>
                        </div>
                        <a href="/product?name=Google%20Pixel%207&price=379&img=https://images.unsplash.com/photo-1678911820864-e2c567c655d7?q=80&w=400" class="btn-primary">Détails & Devis</a>
                    </div>
                </div>

                <div class="fade-in-up" style="margin-top: 4rem; background: var(--color-dark); color: white; padding: 3rem; border-radius: var(--radius); display: flex; align-items: center; justify-content: space-between; gap: 2rem; flex-wrap: wrap;">
                    <div style="flex: 1; min-width: 300px;">
                        <h2 style="font-family: var(--font-title); font-size: 2.5rem; margin-bottom: 1rem; color: var(--color-primary);">Pas encore prêt à changer ?</h2>
                        <p style="color: #ccc; font-size: 1.1rem;">Économisez de l'argent et faites un geste pour la planète. Nous réparons votre smartphone actuel en 30 minutes.</p>
                    </div>
                    <a href="/reparation" class="btn-primary" style="padding: 1rem 2rem; font-size: 1.1rem;">Faire réparer mon appareil</a>
                </div>
            </div>
        </section>
    </main>
</Layout>
