---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="fr" class="bg-[#080808]">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Revendre mon téléphone | La Brigade Mobile</title>
  <meta name="description" content="Obtenez une estimation immédiate pour votre smartphone. Rachat rapide, paiement le jour même." />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['-apple-system', 'BlinkMacSystemFont', 'SF Pro Display', 'Segoe UI', 'sans-serif'],
          },
        }
      }
    }
  </script>
  <style>
    /* Neutralise global.css pour cette page uniquement */
    body {
      background-color: #f5f5f7 !important;
      color: #1d1d1f !important;
      font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Segoe UI', sans-serif !important;
    }
    h1, h2, h3, h4, h5, h6 {
      font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Segoe UI', sans-serif !important;
      letter-spacing: normal !important;
      text-transform: none !important;
    }

    /* ── Animations d'entrée ── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .hero-eyebrow { animation: fadeUp 0.6s ease both; animation-delay: 0.1s; }
    .hero-title   { animation: fadeUp 0.7s ease both; animation-delay: 0.25s; }
    .hero-sub     { animation: fadeUp 0.7s ease both; animation-delay: 0.42s; }

    /* ── Couleurs DA ── */
    .hero-accent { color: #1d1d1f; }

    /* ── Banner layout ── */
    .hero-banner {
      width: 100%;
      position: relative;
      display: block;
    }
    .hero-banner-bg {
      display: block;
      width: 100%;
      height: auto;
      z-index: 0;
    }
    .hero-banner-content {
      position: absolute;
      top: 50%;
      left: 7%;
      transform: translateY(-50%);
      z-index: 1;
      max-width: 36%;
    }
    @media (max-width: 768px) {
      .hero-banner-content { max-width: 65%; left: 5%; }
    }
    @media (max-width: 480px) {
      .hero-banner { display: flex; flex-direction: column; }
      .hero-banner-bg { height: 260px; object-fit: cover; object-position: center top; width: 100%; }
      .hero-banner-content {
        position: static;
        transform: none;
        max-width: 100%;
        left: auto;
        padding: 1.75rem 1.25rem 2.5rem;
        background: #f5f5f7;
      }
      .hero-cta { display: block; text-align: center; width: 100%; padding: 1rem; font-size: 1.05rem; }
    }

    /* ── Bouton CTA pill ── */
    .hero-cta {
      display: inline-block;
      padding: 0.75rem 1.75rem;
      background: #1d1d1f;
      color: #f5f5f7;
      font-size: 0.95rem;
      font-weight: 500;
      letter-spacing: -0.01em;
      border: none;
      border-radius: 2rem;
      cursor: pointer;
      margin-bottom: 0;
      transition: background 0.2s ease, transform 0.18s ease;
    }
    .hero-cta:hover {
      background: #c94f00;
      transform: scale(1.03);
    }
    .hero-cta:active { transform: scale(0.98); }
  </style>
</head>
<body class="bg-[#080808] text-white font-sans antialiased">

  <Header />

  <!-- Hero banner style Apple -->
  <section class="hero-banner">
    <img class="hero-banner-bg" src="/hero-reprise.png" alt="" aria-hidden="true" />

    <div class="hero-banner-content">

      <h1 class="hero-title" style="font-size: clamp(1.6rem, 2.8vw, 2.6rem); font-weight: 700; letter-spacing: -0.02em; line-height: 1.12; color: #1d1d1f; margin-bottom: 1.5rem;">
        Revendez votre<br />
        téléphone<br />
        <span class="hero-accent" style="color:#c94f00;">au meilleur prix.</span>
      </h1>

      <a href="/estimer" class="hero-cta">Estimer mon téléphone</a>

    </div>
  </section>

  <Footer />

</body>
</html>
